{
  "name": "product-feedback-app-backend",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun --watch ./src/app.ts",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "db:generate": "bunx --bun prisma generate",
    "db:push": "bunx --bun prisma db push",
    "db:migrate:dev": "bunx --bun prisma migrate dev",
    "db:migrate:deploy": "bunx --bun prisma migrate deploy",
    "db:seed": "bunx --bun prisma db seed",
    "db:studio": "bunx --bun prisma studio",
    "db:reset": "bunx --bun prisma migrate reset",
    "db:push:test": "bun --env-file=.env.test run db:push",
    "db:seed:test": "bun --env-file=.env.test run db:seed",
    "db:studio:test": "bun --env-file=.env.test run db:studio",
    "db:reset:test": "bun --env-file=.env.test run db:reset",
    "test": "vitest run",
    "test:watch": "vitest watch"
  },
  "dependencies": {
    "@hono/standard-validator": "0.2.2",
    "@hono/structured-logger": "0.1.0",
    "@hono/zod-validator": "0.7.6",
    "@prisma/adapter-neon": "7.7.0",
    "@prisma/adapter-pg": "7.7.0",
    "@prisma/client": "7.7.0",
    "@scalar/hono-api-reference": "0.10.7",
    "bcryptjs": "3.0.3",
    "hono": "4.12.12",
    "hono-openapi": "1.3.0",
    "pino": "10.3.1",
    "pino-pretty": "13.1.3",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@faker-js/faker": "10.4.0",
    "@types/bun": "1.3.12",
    "eslint": "9.39.4",
    "eslint-plugin-perfectionist": "5.8.0",
    "prisma": "7.7.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.58.1",
    "vitest": "4.1.4"
  }
}
