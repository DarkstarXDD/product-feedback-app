{
  "name": "product-feedback-app-backend",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun --watch main.ts",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "db:seed": "bunx --bun prisma db seed",
    "db:seed:test": "bun --env-file=.env.test run db:seed",
    "db:studio": "bunx --bun prisma studio",
    "db:studio:test": "bun --env-file=.env.test run db:studio",
    "db:generate": "bunx --bun prisma generate",
    "db:push": "bunx --bun prisma db push",
    "db:push:test": "bun --env-file=.env.test run db:push",
    "db:migrate:dev": "bunx --bun prisma migrate dev",
    "db:migrate:deploy": "bunx --bun prisma migrate deploy",
    "db:reset": "bunx --bun prisma migrate reset",
    "db:reset:test": "bun --env-file=.env.test run db:reset",
    "test": "vitest run",
    "test:watch": "vitest watch"
  },
  "dependencies": {
    "@prisma/adapter-libsql": "7.4.2",
    "@prisma/adapter-neon": "7.4.2",
    "@prisma/client": "7.4.2",
    "bcryptjs": "3.0.3",
    "hono": "4.12.5",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@faker-js/faker": "10.3.0",
    "@types/bun": "1.3.10",
    "eslint": "9.39.4",
    "eslint-plugin-perfectionist": "5.6.0",
    "prisma": "7.4.2",
    "typescript": "5.9.3",
    "typescript-eslint": "8.56.1",
    "vitest": "4.0.18"
  }
}
